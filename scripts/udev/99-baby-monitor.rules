# Logitech C270 HD Webcam — stable device symlinks
# Video node: always available as /dev/baby-cam regardless of enumeration order
ACTION=="add", SUBSYSTEM=="video4linux", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="0825", ENV{ID_V4L_CAPABILITIES}=="*:capture:*", SYMLINK+="baby-cam", TAG+="systemd"
