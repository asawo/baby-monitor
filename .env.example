# Copy this file to .env and fill in your values
PI_USER=pi
PI_HOST=monitor.local
REMOTE=/home/pi/monitor
PI_IP=192.168.1.100

# Cry detection (detect.service)
# Sign up at https://ntfy.sh or self-host; pick a hard-to-guess topic name
NTFY_TOPIC=your-unique-topic
NTFY_URL=https://ntfy.sh
CRY_THRESHOLD=0.3
NOTIFY_COOLDOWN=120
