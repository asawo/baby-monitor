# Copy this file to .env and fill in your values
PI_USER=pi
PI_HOST=monitor.local
REMOTE=/home/pi/monitor
PI_IP=192.168.1.100

# Sound detection (detect.service)
# Sign up at https://ntfy.sh or self-host; pick a hard-to-guess topic name
NTFY_TOPIC=your-unique-topic
NTFY_URL=https://ntfy.sh
CRY_THRESHOLD=0.3
CRY_COOLDOWN=120
FART_THRESHOLD=0.3
FART_COOLDOWN=120
WETNESS_THRESHOLD=0.5
WETNESS_HF_CUTOFF=1000
DEBUG_AUDIO=0
